<Page x:Class="AdvancedChat.Desktop.Views.ChatView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Chat">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ChatBubbleOutline" Width="24" Height="24" Margin="0,0,16,0"/>
                    <TextBlock Text="Rooms" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
                    <TextBox x:Name="RoomIdBox" materialDesign:HintAssist.Hint="Room ID" Width="100" Margin="32,0,16,0" Foreground="White" materialDesign:HintAssist.Foreground="LightGray" VerticalAlignment="Center"/>
                    <Button Content="JOIN" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="White" BorderBrush="White" Click="Join_Click" materialDesign:ButtonAssist.CornerRadius="16"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Circle" x:Name="StatusIcon" Foreground="Red" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Disconnected" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- Messages Area -->
        <ListBox x:Name="MessagesList" Grid.Row="1" Margin="16" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card Margin="4,8" Padding="12" materialDesign:ElevationAssist.Elevation="Dp1" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignCardBackground}">
                        <StackPanel>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="15"/>
                        </StackPanel>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input Area -->
        <materialDesign:Card Grid.Row="2" Margin="16" Padding="8,8,8,8" UniformCornerRadius="24" materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="MessageBox" materialDesign:HintAssist.Hint="Type a message..." Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderThickness="0" FontSize="16" VerticalAlignment="Center" KeyDown="MessageBox_KeyDown"/>
                <Button Grid.Column="1" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Margin="8,0,0,0" Click="Send_Click">
                    <materialDesign:PackIcon Kind="Send" Width="20" Height="20"/>
                </Button>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
